	author = {Niarakis, Anna and Laubenbacher, Reinhard and An, Gary and Ilan, Yaron and Fisher, Jasmin and Flobak, Åsmund and Reiche, Kristin and Rodríguez Martínez, María and Geris, Liesbet and Ladeira, Luiz and Veschini, Lorenzo and Blinov, Michael L. and Messina, Francesco and Fonseca, Luis L. and Ferreira, Sandra and Montagud, Arnau and Noël, Vincent and Marku, Malvina and Tsirvouli, Eirini and Torres, Marcella M. and Harris, Leonard A. and Sego, T. J. and Cockrell, Chase and Shick, Amanda E. and Balci, Hasan and Salazar, Albin and Rian, Kinza and Hemedan, Ahmed Abdelmonem and Esteban-Medina, Marina and Staumont, Bernard and Hernandez-Vargas, Esteban and Martis B, Shiny and Madrid-Valiente, Alejandro and Karampelesis, Panagiotis and Sordo Vieira, Luis and Harlapur, Pradyumna and Kulesza, Alexander and Nikaein, Niloofar and Garira, Winston and Malik Sheriff, Rahuman S. and Thakar, Juilee and Tran, Van Du T. and Carbonell-Caballero, Jose and Safaei, Soroush and Valencia, Alfonso and Zinovyev, Andrei and Glazier, James A.},
	month = nov,

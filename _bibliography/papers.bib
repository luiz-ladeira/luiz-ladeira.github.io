	author = {Mishima, Marcella Duarte Villas and Ladeira, Luiz Carlos Maia and Da Silva, Bárbara Pereira and Toledo, Renata Celi Lopes and De Oliveira, Thomás Valente and Costa, Neuza Maria Brunoro and Martino, Hércia Stampini Duarte},

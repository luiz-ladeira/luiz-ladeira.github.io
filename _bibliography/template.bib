% =============================================================================
% TEMPLATE / FIELD REFERENCE  —  papers.bib for THIS al-folio site
% =============================================================================
% This file is a REFERENCE ONLY. The site renders publications from
% `_bibliography/papers.bib` (set in _config.yml: scholar.bibliography).
% Copy the entries you need into papers.bib and delete the placeholders.
%
% It documents exactly which fields THIS version of the theme renders, based
% on the entry layout in `_layouts/bib.html`. Fields that other al-folio
% versions support but THIS one ignores are listed at the bottom so you don't
% waste time on them.
%
% -----------------------------------------------------------------------------
% HOW AN ENTRY IS DISPLAYED (left -> right, top -> bottom)
% -----------------------------------------------------------------------------
%   [ preview image OR abbr badge ]  |  Title (plain text, not a link)
%                                     |  Authors (you are auto-highlighted)
%                                     |  Venue, Month Year
%                                     |  note (a second plain line, if present)
%                                     |  [ Abs ] [ arXiv ] [ Bib ] [ HTML ]
%                                     |  [ PDF ] [ Supp ] [ Blog ] [ Code ]
%                                     |  [ Poster ] [ Slides ] [ Website ]
%                                     |  (Altmetric + Dimensions badges)
%
% Grouping/sorting is by `year`, newest first (_config.yml: scholar.group_by).
%
% =============================================================================
% FIELD REFERENCE
% =============================================================================
%
% IDENTITY (required)
%   key        The citation key, e.g. @article{ladeira_liver_2025, ...}.
%              Must be unique. Becomes the entry's HTML anchor (#key).
%   title      Paper title. Plain text. Use {Braces} to protect {Capitals}
%              or math, e.g. {Liver {PM}s} keeps "PM" uppercase.
%   author     "First Last and First Last" OR "Last, First and Last, First".
%              Separate every author with " and ". Your own name is shown in
%              italics automatically (matched against scholar.last_name /
%              scholar.first_name in _config.yml).
%   year       Four-digit year. Drives grouping AND the displayed date. REQUIRED
%              — without it the entry falls out of the year grouping.
%
% VENUE (depends on entry type — only the matching one is printed)
%   journal    Shown for @article.                 e.g. {Frontiers in Toxicology}
%   booktitle  Shown for @inproceedings/@incollection, printed as "In <booktitle>".
%   school     Shown for @phdthesis/@mastersthesis/@thesis.
%   month      Optional. Printed after the venue as "Month Year". Use a name or
%              3-letter form: {April} or {apr}. A number prints as-is.
%   note       Optional. A second plain line under the venue. Use it as the
%              "venue" for @misc entries (preprints, software, talks), e.g.
%              note = {Preprint on bioRxiv} or note = {Software, v2.1.0}.
%
% LINK BUTTONS (each present field adds one button)
%   pdf        PDF button. Bare filename -> resolved from `assets/pdf/`.
%              A full http(s):// link is used as-is.   e.g. {ladeira_2025.pdf}
%   supp       Supplementary file. Same rule as pdf (assets/pdf/ or URL).
%   poster     Poster file/URL. Same rule as pdf.
%   slides     Slides file/URL. Same rule as pdf.
%   html       "HTML" button — the publisher / article landing page (full URL).
%              NOTE: use this for the article link; the `url` field is NOT shown.
%   code       "Code" button (full URL, e.g. a GitHub repo).
%   blog       "Blog" button (full URL).
%   website    "Website" button (full URL).
%   arxiv      "arXiv" button. Give ONLY the id (e.g. {2501.01234}); it links to
%              arxiv.org/abs/<id>.
%
% THUMBNAIL / BADGE (left column)
%   preview    Image shown left of the entry. Bare filename -> resolved from
%              `assets/img/publication_preview/`; a full URL is used as-is.
%              Use ~300x300px PNG/JPG/GIF. Requires enable_publication_thumbnails.
%   abbr       Short venue tag shown as a badge when there is no preview, e.g.
%              {Front. Tox.}. Optionally give it a color/link by adding a
%              matching entry in `_data/venues.yml`.
%
% CITATION BADGES (need enable_publication_badges in _config.yml — already on)
%   doi        Digital Object Identifier (no URL, just 10.xxxx/...). Powers BOTH
%              the Altmetric and Dimensions badges, and is the single most useful
%              optional field. Strongly recommended.
%   dimensions Set {true} to force a Dimensions citation badge (uses doi/pmid).
%   altmetric  Altmetric id to force an Altmetric badge; usually unnecessary if
%              `doi` is present. Use {true} or the numeric id.
%   eprint     arXiv id used as the Altmetric source for preprints.
%   pmid       PubMed id — alternative source for both badges.
%   isbn       ISBN — Altmetric source for books.
%
% INTERACTIVE / FLAGS
%   abstract   Adds an "Abs" button that expands the abstract inline. ~100-200
%              words. Braces protect special characters.
%   bibtex_show Set {true} to add a "Bib" button showing a clean BibTeX block
%              (custom display fields above are stripped from it automatically).
%   selected   Set {true} to include the paper in the about-page "selected
%              papers" list. In THIS version it does NOT create a featured
%              section on the publications page; it only feeds the homepage list
%              (which also needs `selected_papers: true` in _pages/about.md).
%
% STANDARD BibTeX FIELDS THAT ARE STORED BUT NOT PRINTED IN THE ENTRY LINE
%   volume, number, pages, publisher, edition, editor, address, issn, ...
%   These are kept in the record and appear inside the "Bib" popup (when
%   bibtex_show = {true}); the one-line listing does not display them.
%
% FIELDS OTHER al-folio VERSIONS USE BUT THIS ONE IGNORES (do not rely on them)
%   annotation, additional_info, award, google_scholar_id, location, url
%   (`url` is only kept in the BibTeX record — it is never shown as a link.)
%
% =============================================================================
% EXAMPLES (valid for this version — replace with your own, then delete)
% =============================================================================

% --- Journal article: most fields demonstrated -------------------------------
@article{lastname_topic_2025,
  title       = {A descriptive title, with {Protected} capitals and {AOP}s},
  author      = {Lastname, Firstname and Coauthor, A. B. and Senior, C.},
  journal     = {Journal of Example Studies},
  year        = {2025},
  month       = {apr},
  volume      = {12},          % stored; shown only in the Bib popup
  number      = {3},           % stored; shown only in the Bib popup
  pages       = {101--115},    % stored; shown only in the Bib popup
  doi         = {10.0000/example.2025.0001},  % powers Altmetric + Dimensions
  html        = {https://example.org/articles/0001},  % "HTML" button (article page)
  pdf         = {lastname_2025_example.pdf},   % file in assets/pdf/
  preview     = {example_preview.png},         % image in assets/img/publication_preview/
  abbr        = {J. Ex. Stud.},
  abstract    = {One or two paragraphs summarising the work. This text is
                 hidden behind the "Abs" button and expands inline when clicked.},
  bibtex_show = {true},
  dimensions  = {true},
  selected    = {true}
}

% --- Journal article: minimal valid entry ------------------------------------
@article{lastname_minimal_2024,
  title   = {The smallest entry that still renders correctly},
  author  = {Lastname, Firstname and Other, Author},
  journal = {Another Example Journal},
  year    = {2024},
  doi     = {10.0000/example.2024.0042}
}

% --- Conference paper: venue comes from booktitle ("In ...") ------------------
@inproceedings{lastname_conf_2024,
  title     = {A method presented at a conference},
  author    = {Lastname, Firstname and Collaborator, X.},
  booktitle = {Proceedings of the Example Conference (EXCONF)},
  year      = {2024},
  doi       = {10.0000/exconf.2024.7},
  slides    = {lastname_2024_slides.pdf},   % file in assets/pdf/
  pdf       = {lastname_2024_exconf.pdf}
}

% --- Book chapter ------------------------------------------------------------
@incollection{lastname_chapter_2023,
  title     = {A chapter inside an edited volume},
  author    = {Lastname, Firstname and Editorhelper, Y.},
  booktitle = {Methods in Example Science},
  editor    = {Editor, Lead},   % stored; shown only in the Bib popup
  year      = {2023},
  doi       = {10.0000/mes.2023.12},
  bibtex_show = {true}
}

% --- Thesis: venue comes from school -----------------------------------------
@phdthesis{lastname_thesis_2021,
  title  = {Doctoral dissertation title},
  author = {Lastname, Firstname},
  school = {University of Example},
  year   = {2021}
}

% --- Preprint (use note as the venue, eprint for the Altmetric badge) ---------
@misc{lastname_preprint_2025,
  title  = {A preprint not yet peer reviewed},
  author = {Lastname, Firstname and Coauthor, A. B.},
  year   = {2025},
  month  = {jan},
  doi    = {10.1101/2025.01.01.000000},
  note   = {Preprint on bioRxiv. Under review.},
  arxiv  = {2501.00000}   % adds an "arXiv" button -> arxiv.org/abs/2501.00000
}

% --- Software / dataset (use note + code/website buttons) --------------------
@misc{lastname_software_2024,
  title   = {{ToolName}: a package for doing the thing},
  author  = {Lastname, Firstname},
  year    = {2024},
  note    = {Software, v1.2.0},
  code    = {https://github.com/youruser/toolname},
  website = {https://youruser.github.io/toolname}
}
